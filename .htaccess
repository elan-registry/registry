# Disable directory browsing for security
Options -Indexes

# Security headers
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Deny access to sensitive files
<Files "*.env*">
    Require all denied
</Files>

<Files "CLAUDE.md">
    Require all denied
</Files>

<Files "composer.json">
    Require all denied
</Files>

<Files "composer.lock">
    Require all denied
</Files>

<Files "VERSION">
    Require all denied
</Files>

# Block access to sensitive directories using RewriteRule
RewriteEngine On

# Block access to backup directories
RewriteRule ^@backup/ - [F,L]

# Block access to node_modules
RewriteRule ^node_modules/ - [F,L]

# Block access to vendor directory from web
RewriteRule ^vendor/ - [F,L]

# Block access to test directories
RewriteRule ^tests/ - [F,L]

# Block access to SQL directory
RewriteRule ^SQL/ - [F,L]

# Block access to FIX directory except index.php (admin interface)
RewriteRule ^FIX/(?!index\.php$) - [F,L]
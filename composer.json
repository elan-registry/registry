{
    "name": "jimboone/elan_registry",
    "description": "Lotus Elan Registry",
    "type": "project",
    "require": {
        "php": ">=8.2.29",
        "johnathanmiller/secure-env-php": "^2.0"
    },
    "authors": [
        {
            "name": "Jim Boone",
            "email": "jim@unibrain.org"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test:quick": "vendor/bin/phpunit --testsuite=Unit --stop-on-failure",
        "test:medium": "vendor/bin/phpunit --testsuite=Unit,Integration --stop-on-failure",
        "test:full": "vendor/bin/phpunit --testsuite=All",
        "test:coverage": "vendor/bin/phpunit --testsuite=All --coverage-html=coverage",
        "test:unit": "vendor/bin/phpunit --testsuite=Unit",
        "test:integration": "vendor/bin/phpunit --testsuite=Integration",
        "test:regression": "vendor/bin/phpunit --testsuite=Regression"
    }
}

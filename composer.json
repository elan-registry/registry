{
    "name": "jimboone/elan_registry",
    "description": "Lotus Elan Registry",
    "type": "project",
    "require": {
        "php": ">=8.2.29"
    },
    "authors": [
        {
            "name": "Jim Boone",
            "email": "jim@unibrain.org"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test:quick": "vendor/bin/phpunit --testsuite=Unit",
        "test:medium": "vendor/bin/phpunit --testsuite=Unit,Integration",
        "test:full": "vendor/bin/phpunit --testsuite=All",
        "test:coverage": "vendor/bin/phpunit --testsuite=All --coverage-html=coverage",
        "test:unit": "vendor/bin/phpunit --testsuite=Unit",
        "test:integration": "vendor/bin/phpunit --testsuite=Integration",
        "test:regression": "vendor/bin/phpunit --testsuite=Regression",
        "test:cars": "vendor/bin/phpunit --testsuite=Unit.Cars",
        "test:users": "vendor/bin/phpunit --testsuite=Unit.Users",
        "test:security": "vendor/bin/phpunit --testsuite=Unit.Security",
        "test:uploads": "vendor/bin/phpunit --testsuite=Unit.Uploads",
        "test:system": "vendor/bin/phpunit --testsuite=Unit.System",
        "test:database": "vendor/bin/phpunit --testsuite=Integration.Database",
        "test:api": "vendor/bin/phpunit --testsuite=Integration.API",
        "test:workflow": "vendor/bin/phpunit --testsuite=Integration.Workflow",
        "test:fast": "vendor/bin/phpunit --group=fast",
        "test:slow": "vendor/bin/phpunit --group=slow",
        "test:db": "vendor/bin/phpunit --group=database"
    }
}

{
    "name": "jimboone/elan_registry",
    "description": "Lotus Elan Registry",
    "type": "project",
    "require": {
        "php": ">=8.2.29"
    },
    "authors": [
        {
            "name": "Jim Boone",
            "email": "jim@unibrain.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "ElanRegistry\\Exceptions\\": "usersc/classes/Exceptions/",
            "ElanRegistry\\Reference\\": "usersc/classes/ElanRegistry/Reference/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "_comment": "Unit tests (mocks, no database) vs Integration tests (real database)",
        "test:quick": "vendor/bin/phpunit -c phpunit-unit.xml --testsuite=Unit",
        "test:unit": "vendor/bin/phpunit -c phpunit-unit.xml --testsuite=Unit",
        "test:regression": "vendor/bin/phpunit -c phpunit-unit.xml --testsuite=Regression",
        "test:unit:all": "vendor/bin/phpunit -c phpunit-unit.xml",
        "test:integration": "vendor/bin/phpunit -c phpunit-integration.xml --testsuite=Integration",
        "test:database": "vendor/bin/phpunit -c phpunit-integration.xml tests/integration/database",
        "test:api": "vendor/bin/phpunit -c phpunit-integration.xml tests/integration/api",
        "test:workflow": "vendor/bin/phpunit -c phpunit-integration.xml tests/integration/workflow",
        "test:full": "vendor/bin/phpunit -c phpunit-unit.xml && vendor/bin/phpunit -c phpunit-integration.xml",
        "test:coverage": "vendor/bin/phpunit -c phpunit-unit.xml --coverage-html=coverage",
        "test:medium": "vendor/bin/phpunit -c phpunit-unit.xml && vendor/bin/phpunit -c phpunit-integration.xml tests/integration/database",
        "test:cars": "vendor/bin/phpunit -c phpunit-unit.xml tests/unit/cars",
        "test:users": "vendor/bin/phpunit -c phpunit-unit.xml tests/unit/users",
        "test:fast": "vendor/bin/phpunit -c phpunit-unit.xml --group=fast",
        "test:slow": "vendor/bin/phpunit -c phpunit-unit.xml --group=slow",
        "check": "php scripts/check-coding-standards.php . && vendor/bin/phpstan analyse --no-progress --memory-limit=512M && npx eslint app/assets/js/",
        "check:php": "php scripts/check-coding-standards.php . && vendor/bin/phpstan analyse --no-progress --memory-limit=512M"
    }
}

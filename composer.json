{
    "name": "jimboone/elan_registry",
    "description": "Lotus Elan Registry",
    "type": "project",
    "require": {
        "php": ">=8.2.29",
        "robmorgan/phinx": "^0.16.12"
    },
    "authors": [
        {
            "name": "Jim Boone",
            "email": "jim@unibrain.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "ElanRegistry\\Exceptions\\": "usersc/classes/Exceptions/",
            "ElanRegistry\\Reference\\": "usersc/classes/Reference/",
            "ElanRegistry\\Admin\\": "usersc/classes/admin/",
            "ElanRegistry\\": "usersc/classes/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        }
    },
    "scripts": {
        "_comment": "Unit tests (mocks, no database) vs Integration tests (real database)",
        "test:quick": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml --testsuite=Unit",
        "test:unit": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml --testsuite=Unit",
        "test:regression": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml --testsuite=Regression",
        "test:unit:all": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml",
        "test:integration": "@php vendor/phpunit/phpunit/phpunit -c phpunit-integration.xml --testsuite=Integration",
        "test:database": "@php vendor/phpunit/phpunit/phpunit -c phpunit-integration.xml tests/integration/database",
        "test:api": "@php vendor/phpunit/phpunit/phpunit -c phpunit-integration.xml tests/integration/api",
        "test:workflow": "@php vendor/phpunit/phpunit/phpunit -c phpunit-integration.xml tests/integration/workflow",
        "test:full": ["@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml", "@php vendor/phpunit/phpunit/phpunit -c phpunit-integration.xml"],
        "test:coverage": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml --coverage-html=coverage",
        "test:medium": ["@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml", "@php vendor/phpunit/phpunit/phpunit -c phpunit-integration.xml tests/integration/database"],
        "test:cars": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml tests/unit/cars",
        "test:users": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml tests/unit/users",
        "test:fast": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml --group=fast",
        "test:slow": "@php vendor/phpunit/phpunit/phpunit -c phpunit-unit.xml --group=slow",
        "check": "php scripts/check-coding-standards.php . && vendor/bin/phpstan analyse --no-progress --memory-limit=512M && npx eslint app/assets/js/",
        "check:php": "php scripts/check-coding-standards.php . && vendor/bin/phpstan analyse --no-progress --memory-limit=512M",
        "migrate": "vendor/bin/phinx migrate",
        "migrate:status": "vendor/bin/phinx status",
        "migrate:dry-run": "vendor/bin/phinx migrate --dry-run",
        "migrate:rollback": "vendor/bin/phinx rollback"
    }
}

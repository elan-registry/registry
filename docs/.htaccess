# Disable directory browsing for documentation
Options -Indexes

# Allow reading documentation files but prevent browsing
<Files "*.md">
    Require all granted
</Files>

<Files "*.html">
    Require all granted
</Files>

# Protect any sensitive documentation
<Files "ENVIRONMENT.md">
    Require all denied
</Files>

# Redirects for doc reorganization (#559)
Redirect 301 /docs/reference-library.php /docs/reference/index.php
Redirect 301 /docs/faq/index.php /docs/guides/index.php
Redirect 301 /docs/faq/paint-colors.php /docs/reference/paint-colors.php
Redirect 301 /docs/faq/admin/index.php /docs/admin/index.php
Redirect 301 /docs/chassis-validation.php /docs/reference/chassis-validation.php


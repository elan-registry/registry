#!/bin/bash

#
# Pre-commit hook to enforce coding standards
#
# This hook runs before each commit and prevents commits that violate
# the Elan Registry coding standards. It only checks staged files.
#
# To install: git config core.hooksPath .githooks
# To bypass: git commit --no-verify (use sparingly!)
#
# Checks performed:
#   1. PHP Coding Standards (security, types, documentation)
#   2. Markdown Linting (formatting)
#   3. Regression Test Issue Linking (traceability)
#   4. Unit Tests (if critical files changed)
#   5. PHPStan Static Analysis (if PHP files changed)
#   6. JavaScript Linting (if JS files changed and ESLint available)
#

set -e

echo "🔍 Running pre-commit quality checks..."

# Get list of staged files by type
STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)
STAGED_JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.js$' | grep -v '\.min\.js$' || true)
STAGED_REGRESSION_TESTS=$(git diff --cached --name-only --diff-filter=ACM | grep '^tests/regression/.*\.php$' || true)

# Check if any critical files are modified (tests, core classes, etc.)
CRITICAL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(php|json)$|phpunit\.xml' || true)

if [ -z "$STAGED_PHP_FILES" ] && [ -z "$STAGED_MD_FILES" ] && [ -z "$STAGED_JS_FILES" ] && [ -z "$CRITICAL_FILES" ] && [ -z "$STAGED_REGRESSION_TESTS" ]; then
    echo "✅ No relevant files staged, skipping quality checks"
    exit 0
fi

# Create temporary directory for staged files
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

echo "📁 Checking staged files only..."

# Copy staged versions of files to temp directory
ALL_STAGED_FILES="$STAGED_PHP_FILES $STAGED_MD_FILES"
for FILE in $ALL_STAGED_FILES; do
    if [ -n "$FILE" ]; then
        # Create directory structure in temp
        mkdir -p "$TEMP_DIR/$(dirname "$FILE")"
        # Get staged version of file
        git show ":$FILE" > "$TEMP_DIR/$FILE"
        echo "  • $FILE"
    fi
done

# Step 1: Run coding standards checker on staged PHP files
echo ""
echo "📋 Step 1: PHP Coding Standards"
if [ -n "$STAGED_PHP_FILES" ]; then
    if php scripts/check-coding-standards.php "$TEMP_DIR" --staged; then
        echo "✅ Passed"
    else
        echo ""
        echo "❌ COMMIT BLOCKED: Fix the issues above, stage fixes, and try again."
        echo "   Bypass (not recommended): git commit --no-verify"
        exit 1
    fi
else
    echo "⏭️  No PHP files staged"
fi

# Step 2: Run markdown linting on staged MD files
echo ""
echo "📝 Step 2: Markdown Lint"
if [ -n "$STAGED_MD_FILES" ]; then
    # Create list of staged markdown files for linting
    MD_FILES_LIST=""
    for FILE in $STAGED_MD_FILES; do
        if [ -n "$FILE" ]; then
            MD_FILES_LIST="$MD_FILES_LIST $TEMP_DIR/$FILE"
        fi
    done

    if npx markdownlint-cli2 $MD_FILES_LIST 2>/dev/null; then
        echo "✅ Passed"
    else
        echo ""
        echo "❌ COMMIT BLOCKED: Fix markdown issues above, stage fixes, and try again."
        echo "   Rules: https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md"
        exit 1
    fi
else
    echo "⏭️  No markdown files staged"
fi

# Step 3: Validate regression test issue linking
echo ""
echo "🔗 Step 3: Regression Test Validation"
if [ -n "$STAGED_REGRESSION_TESTS" ]; then
    REGRESSION_ERRORS=0

    for TEST_FILE in $STAGED_REGRESSION_TESTS; do
        if [ -n "$TEST_FILE" ]; then
            STAGED_CONTENT=$(git show ":$TEST_FILE")
            FILENAME=$(basename "$TEST_FILE" .php)

            # Check filename pattern: Issue{Number}RegressionTest
            if [[ ! "$FILENAME" =~ ^Issue[0-9]+RegressionTest$ ]]; then
                echo "  ❌ $TEST_FILE: Invalid filename. Must be: Issue{Number}RegressionTest.php"
                REGRESSION_ERRORS=$((REGRESSION_ERRORS + 1))
                continue
            fi

            ISSUE_NUMBER=$(echo "$FILENAME" | sed 's/Issue\([0-9]*\)RegressionTest/\1/')

            if ! echo "$STAGED_CONTENT" | grep -q "@issue $ISSUE_NUMBER"; then
                echo "  ❌ $TEST_FILE: Missing @issue $ISSUE_NUMBER annotation"
                REGRESSION_ERRORS=$((REGRESSION_ERRORS + 1))
            fi

            if ! echo "$STAGED_CONTENT" | grep -q "@link.*github.com.*issues/$ISSUE_NUMBER"; then
                echo "  ❌ $TEST_FILE: Missing @link annotation"
                REGRESSION_ERRORS=$((REGRESSION_ERRORS + 1))
            fi
        fi
    done

    if [ $REGRESSION_ERRORS -gt 0 ]; then
        echo ""
        echo "❌ COMMIT BLOCKED: Fix issues above. Use template: tests/regression/RegressionTestTemplate.php"
        exit 1
    else
        echo "✅ Passed"
    fi
else
    echo "⏭️  No regression tests staged"
fi

# Step 4: Run fast unit tests (if critical files changed)
echo ""
echo "🧪 Step 4: Unit Tests"
if [ -n "$CRITICAL_FILES" ]; then
    if [ ! -f "composer.json" ] || [ ! -d "vendor" ]; then
        echo "⚠️  Skipping: composer dependencies not installed"
    else
        if vendor/bin/phpunit --testsuite=Unit --exclude-group broken 2>&1; then
            echo "✅ Passed"
        else
            echo ""
            echo "❌ COMMIT BLOCKED: Fix failing tests. Run 'composer test:quick' to verify."
            exit 1
        fi
    fi
else
    echo "⏭️  No critical files changed"
fi

# Step 5: Run PHPStan static analysis (if PHP files changed)
echo ""
echo "🔬 Step 5: PHPStan Static Analysis"
if [ -n "$STAGED_PHP_FILES" ]; then
    if [ -f "vendor/bin/phpstan" ]; then
        if vendor/bin/phpstan analyse --no-progress --memory-limit=512M 2>&1; then
            echo "✅ Passed"
        else
            echo ""
            echo "❌ COMMIT BLOCKED: Fix PHPStan errors above."
            echo "   Bypass (not recommended): git commit --no-verify"
            exit 1
        fi
    else
        echo "⚠️  Skipping: phpstan not installed (composer require --dev phpstan/phpstan)"
    fi
else
    echo "⏭️  No PHP files staged"
fi

# Step 6: Run ESLint on staged JS files (if available)
echo ""
echo "📜 Step 6: JavaScript Lint"
if [ -n "$STAGED_JS_FILES" ]; then
    # Check if eslint is available
    if [ -f "node_modules/.bin/eslint" ] || command -v eslint &> /dev/null; then
        # Create list of staged JS files
        JS_FILES_LIST=""
        for FILE in $STAGED_JS_FILES; do
            if [ -n "$FILE" ]; then
                JS_FILES_LIST="$JS_FILES_LIST $FILE"
            fi
        done

        if npx eslint $JS_FILES_LIST 2>/dev/null; then
            echo "✅ Passed"
        else
            echo ""
            echo "❌ COMMIT BLOCKED: Fix ESLint errors above."
            echo "   Bypass (not recommended): git commit --no-verify"
            exit 1
        fi
    else
        echo "⏭️  ESLint not installed (optional: npm install)"
    fi
else
    echo "⏭️  No JavaScript files staged"
fi

# All checks passed
echo ""
echo "🎉 All pre-commit checks passed!"
exit 0
# Files and directories excluded from test/prod deployments.
# Used by server-side post-receive hooks to clean up after git checkout.
# Paths are relative to the work tree root.

# Claude Code / AI tooling
.claude/

# GitHub (CI workflows, issue templates, bot configs)
.github/
.imgbotconfig

# Git config files (not needed on server)
.githooks/
.gitignore
.gitmessage

# Development documentation (not served to users)
docs/development/
docs/testing/
docs/releases/
docs/PRD.md
docs/README.md

# Tests
tests/

# Scripts (already blocked by .htaccess, but not needed on server)
scripts/

# Linting and static analysis
eslint.config.mjs
phpstan.neon
phpstan-baseline.neon
.markdownlint.json
.markdownlintignore

# Playwright configs
playwright.config.js
playwright.config.prod.js
playwright.config.test.js

# PHP test configs
phpunit.xml
phpunit-unit.xml
phpunit-integration.xml

# Node / JS tooling
package.json
package-lock.json
tsconfig.json

# Composer (dependencies not deployed via git)
composer.json
composer.lock

# Project documentation not needed on server
CLAUDE.md
README.md
SECURITY.md
LICENSE
.env.local.sample
instructions.txt

# Database migrations (run manually, not served)
database/

# Disable directory browsing for security
Options -Indexes

# Allow access to PHP story files but deny directory listings and sensitive files
<Files "*.php">
    Require all granted
</Files>

# Allow access to images and assets for stories
<FilesMatch "\.(jpg|jpeg|png|gif|css|js|html)$">
    Require all granted
</FilesMatch>

# Deny access to any potential sensitive files
<Files "*.txt">
    Require all denied
</Files>

<Files "*.log">
    Require all denied
</Files>
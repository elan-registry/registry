<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         processIsolation="false"
         stopOnFailure="false"
         cacheDirectory=".phpunit.cache"
         backupGlobals="false">
    
    <testsuites>
        <!-- Combined unit test suite (all unit tests) -->
        <testsuite name="Unit">
            <directory>tests/unit</directory>
        </testsuite>

        <!-- Database integration tests (run separately with real DB) -->
        <testsuite name="Integration">
            <directory>tests/integration</directory>
        </testsuite>

        <!-- Integration tests by feature -->
        <testsuite name="Integration.Database">
            <directory>tests/integration/database</directory>
        </testsuite>

        <testsuite name="Integration.API">
            <directory>tests/integration/api</directory>
        </testsuite>

        <testsuite name="Integration.Workflow">
            <directory>tests/integration/workflow</directory>
        </testsuite>

        <!-- Issue-specific regression tests -->
        <testsuite name="Regression">
            <directory>tests/regression</directory>
        </testsuite>

        <!-- All tests combined -->
        <testsuite name="All">
            <directory>tests/unit</directory>
            <directory>tests/integration</directory>
            <directory>tests/regression</directory>
            <exclude>tests/run_tests.php</exclude>
        </testsuite>
    </testsuites>
    
    <php>
        <env name="TESTING" value="true"/>
        <ini name="error_reporting" value="E_ALL"/>
        <ini name="display_errors" value="1"/>
        <ini name="display_startup_errors" value="1"/>
    </php>
    
    <source>
        <include>
            <directory>usersc/classes</directory>
            <directory>app</directory>
        </include>
        <exclude>
            <directory>vendor</directory>
            <directory>users</directory>
            <directory>FIX</directory>
            <directory>tests</directory>
            <file>usersc/classes/test_class.php</file>
        </exclude>
    </source>
</phpunit>
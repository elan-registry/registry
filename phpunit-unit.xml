<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
         bootstrap="tests/bootstrap-unit.php"
         colors="true"
         processIsolation="false"
         stopOnFailure="false"
         cacheDirectory=".phpunit.cache"
         backupGlobals="false">

    <testsuites>
        <!-- Unit tests - use mock infrastructure, no database -->
        <testsuite name="Unit">
            <directory>tests/unit</directory>
        </testsuite>

        <!-- Regression tests - treated as unit tests -->
        <testsuite name="Regression">
            <directory>tests/regression</directory>
        </testsuite>
    </testsuites>

    <php>
        <env name="TESTING" value="true"/>
        <env name="TESTING_UNIT_ONLY" value="true"/>
        <ini name="error_reporting" value="E_ALL"/>
        <ini name="display_errors" value="1"/>
        <ini name="display_startup_errors" value="1"/>
    </php>

    <source>
        <include>
            <directory>usersc/classes</directory>
            <directory>app</directory>
        </include>
        <exclude>
            <directory>vendor</directory>
            <directory>users</directory>
            <directory>FIX</directory>
            <directory>tests</directory>
            <file>usersc/classes/test_class.php</file>
        </exclude>
    </source>
</phpunit>

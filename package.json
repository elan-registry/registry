{
  "name": "elan_registry",
  "version": "1.0.0",
  "description": "This is code for the Lotus Elan Registry hosted at https://elanregistry.org. It is used in conjunction with Userspice (https://userspice.com) to build an online database for Lotus Elan and Lotus Elan +2 cars.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "echo 'UI tests require Playwright setup. Run: npx playwright install && configure web server'",
    "test:ui-note": "echo 'Playwright tests available but require web server configuration'",
    "playwright:install": "npx playwright install",
    "playwright:test": "playwright test",
    "playwright:security": "playwright test tests/playwright/security.test.js",
    "playwright:ui": "playwright test tests/playwright/ui-consistency.test.js",
    "playwright:navigation": "playwright test tests/playwright/navigation.test.js",
    "playwright:functionality": "playwright test tests/playwright/functionality.test.js",
    "playwright:maps": "playwright test tests/playwright/maps-charts.test.js",
    "playwright:csp": "playwright test tests/playwright/csp-validation.spec.js",
    "playwright:headed": "playwright test --headed",
    "playwright:debug": "playwright test --debug",
    "playwright:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unibrain1/elanregistry.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/unibrain1/elanregistry/issues"
  },
  "homepage": "https://github.com/unibrain1/elanregistry#readme",
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}

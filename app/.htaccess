# Disable directory browsing
Options -Indexes
RewriteEngine On

# Deny access to action scripts (should only be called via forms/AJAX)
RewriteRule ^actions/.*\.php$ - [F,L]

# Allow access to API endpoints but disable browsing (handled by Options -Indexes)
# API directory is accessible for valid endpoints

# Protect views directory (should not be directly accessible)
RewriteRule ^views/.*\.php$ - [F,L]